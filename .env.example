# =========================================
# Article -> Video Pipeline: env config
# Copy to .env and fill in.
# =========================================

# --- App ---
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# --- Pipeline defaults ---
NLP_BACKEND=ollama          # ollama | llm | local
ASPECT_RATIO=16:9           # 16:9 | 9:16 | 1:1
SOURCE_LANG=zh
TRANSLATE_TO=                # leave blank to disable; e.g. "en"
VOICE_PRIMARY=zh-CN-XiaoxiaoNeural
VOICE_SECONDARY=en-US-AriaNeural
BGM_ENABLED=true
BURN_SUBTITLES=true
USE_GPU=false               # true => NVENC

# --- Media providers (free) ---
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=

# --- Music providers (free) ---
# Jamendo: https://developer.jamendo.com/v3.0 — sign up to get a client_id.
# Local BGM library is the default (assets/bgm/<mood>/*.mp3); Jamendo is optional.
JAMENDO_CLIENT_ID=

# --- LLM backend (optional, only if NLP_BACKEND=llm) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-5

# --- Ollama backend (optional, only if NLP_BACKEND=ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# --- DeepSeek backend (optional, only if NLP_BACKEND=deepseek) ---
# Get API key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 通义千问 backend (optional, only if NLP_BACKEND=qwen) ---
# Get API key at: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-turbo

# --- 智谱 GLM backend (optional, only if NLP_BACKEND=zhipu) ---
# Get API key at: https://open.bigmodel.cn/
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4

# --- 讯飞星火 backend (optional, only if NLP_BACKEND=spark) ---
# Get credentials at: https://www.xfyun.cn/
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_MODEL=generalv3.5

# --- 百度文心一言 backend (optional, only if NLP_BACKEND=wenxin) ---
# Get credentials at: https://cloud.baidu.com/
WENXIN_API_KEY=
WENXIN_SECRET_KEY=
WENXIN_MODEL=ernie-4.0-8k-latest

# --- Paths ---
CACHE_DIR=./assets/cache
OUTPUT_DIR=./assets/output
